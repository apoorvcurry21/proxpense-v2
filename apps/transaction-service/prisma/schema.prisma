// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}


model TransactionRecord {
  id         String   @id @default(uuid())
  senderId   String
  receiverId String
  amount     Float
  status     String
  createdAt  DateTime @default(now())
}
